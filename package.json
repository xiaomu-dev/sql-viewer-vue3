{
	"name": "@xm-dev/sql-viewer-vue3",
	"version": "1.0.14",
	"description": "Vue3 SQL editor component based on CodeMirror 6 & Element Plus, with syntax highlight, autocomplete, SQL formatter and database query console for admin projects.",
	"type": "module",
	"main": "./dist/sql-viewer-vue3.umd.js",
	"module": "./dist/sql-viewer-vue3.es.js",
	"exports": {
		".": {
			"import": "./dist/sql-viewer-vue3.es.js",
			"require": "./dist/sql-viewer-vue3.umd.js"
		}
	},
	"files": [
		"dist",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"fix": "npm pkg fix",
		"pub": "npm version patch && npm run build && npm publish --access public",
		"pub:minor": "npm version minor && npm run build && npm publish --access public",
		"pub:major": "npm version major && npm run build && npm publish --access public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/xiaomu-dev/sql-viewer-vue3.git"
	},
	"keywords": [
		"vue",
		"codemirror",
		"sql-viewer",
		"sql-editor",
		"sql-console",
		"database-terminal"
	],
	"author": "xiaomu-dev",
	"license": "MIT",
	"peerDependencies": {
		"@element-plus/icons-vue": ">=2.3.0",
		"element-plus": ">=2.14.0 <3.0.0",
		"vue": ">=3.4.0 <4.0.0"
	},
	"dependencies": {},
	"devDependencies": {
		"@codemirror/autocomplete": "^6.20.3",
		"@codemirror/lang-sql": "^6.10.0",
		"@codemirror/state": "^6.7.1",
		"@codemirror/theme-one-dark": "6.1.3",
		"@codemirror/view": "^6.43.6",
		"codemirror": "^6.0.2",
		"sql-formatter": "^15.8.2",
		"@vitejs/plugin-vue": "^6.0.8",
		"sass": "^1.101.0",
		"vite": "^8.1.4",
		"vite-plugin-css-injected-by-js": "^5.0.1",
		"vue": "^3.5.39"
	}
}
